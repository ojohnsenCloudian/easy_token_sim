<?xml version="1.0" encoding="UTF-8" ?>
<Configuration>
    <Properties>
        <Property name="logFilePath">${sys:log.file.path:-/data/logs/cloudian-token.log}</Property>
    </Properties>

    <Appenders>
    <Console name="CONSOLE" target="SYSTEM_OUT">
        <PatternLayout pattern="%d %5p [%t] %c{1}:%M(%L) %m%n"/>
    </Console>

    <RollingRandomAccessFile name="S3APP"
        fileName="${logFilePath}"
        filePattern="${logFilePath}.%d{yyyy-MM-dd}.%i.gz"
        append="true">
        <PatternLayout pattern="%d %5p [%t] %c{1}:%M(%L) %m%n"/>
        <Policies>
            <TimeBasedTriggeringPolicy />
            <SizeBasedTriggeringPolicy size="10 MB"/>
        </Policies>
        <DefaultRolloverStrategy max="10000"/>
    </RollingRandomAccessFile>

    </Appenders>


    <Loggers>
    <Logger name="com.cloudian" additivity="false" level="INFO">
        <AppenderRef ref="S3APP" />
    </Logger>

    <Logger name="com.gemini" additivity="false" level="INFO">
        <AppenderRef ref="S3APP" />
    </Logger>

    <!-- Root Logger -->
    <Root level="INFO">
        <AppenderRef ref="S3APP" />
    </Root>
    </Loggers>
</Configuration>
